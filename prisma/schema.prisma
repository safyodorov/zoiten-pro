// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────────────────

enum UserRole {
  SUPERADMIN
  MANAGER
  VIEWER
}

enum ERP_SECTION {
  PRODUCTS
  PRICES
  WEEKLY_CARDS
  STOCK
  COST
  PROCUREMENT
  SALES
  SUPPORT
  EMPLOYEES
  ADS
  USER_MANAGEMENT
}

enum AbcStatus {
  A
  B
  C
}

enum Availability {
  IN_STOCK
  OUT_OF_STOCK
  DISCONTINUED
  DELETED
}

// ──────────────────────────────────────────────────────────────────
// User
// ──────────────────────────────────────────────────────────────────

model User {
  id                      String                @id @default(cuid())
  email                   String                @unique
  name                    String // DEPRECATED — legacy поле, для новых пользователей заполняется из firstName + lastName
  firstName               String?
  lastName                String?
  employeeId              String?               @unique
  employee                Employee?             @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  password                String // bcrypt hash — never return to client
  plainPassword           String? // plain text для просмотра суперадмином (только внутренняя ERP)
  role                    UserRole              @default(VIEWER)
  allowedSections         ERP_SECTION[] // DEPRECATED — оставлено для отката миграции, см. sectionRoles
  sectionRoles            UserSectionRole[] // актуальный источник прав per раздел
  // Per-user список скрытых WB-складов на странице /stock/wb (quick 260422-oy5).
  // Чисто визуальный фильтр — НЕ влияет на агрегаты.
  stockWbHiddenWarehouses Int[]                 @default([])
  // Phase 16 (STOCK-31): per-user toggle кнопки «По размерам» в /stock/wb.
  stockWbShowSizes        Boolean               @default(false)
  preferences             UserPreference[] // персистентные настройки UI per-user (план 260410-mya)
  assignedTickets         SupportTicket[]       @relation("SupportAssignee") // Phase 8 — назначенные тикеты поддержки
  authoredMessages        SupportMessage[]      @relation("SupportAuthor") // Phase 8 — OUTBOUND сообщения
  returnDecisions         ReturnDecision[]      @relation("ReturnDecider") // Phase 9 — audit log решений по возвратам
  templatesCreated        ResponseTemplate[]    @relation("TemplateCreator") // Phase 11 — шаблоны, созданные пользователем
  templatesUpdated        ResponseTemplate[]    @relation("TemplateUpdater") // Phase 11 — шаблоны, последний раз обновлённые пользователем
  appealsCreated          AppealRecord[]        @relation("AppealCreator") // Phase 11 — обжалования, созданные пользователем
  appealsResolved         AppealRecord[]        @relation("AppealResolver") // Phase 11 — обжалования, резольвенные пользователем
  autoReplyUpdates        AutoReplyConfig[]     @relation("AutoReplyUpdater") // Phase 10 — кто последний редактировал автоответ
  managerStats            ManagerSupportStats[] @relation("ManagerStats") // Phase 13 — денормализованная статистика менеджеров (SUP-39)
  wbTokensUpdated         WbApiToken[]          @relation("WbTokenUpdater") // Quick 260512-jxh
  isActive                Boolean               @default(true)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
}

enum SectionRole {
  VIEW // только просмотр
  MANAGE // полный доступ
}

model UserSectionRole {
  id      String      @id @default(cuid())
  userId  String
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  section ERP_SECTION
  role    SectionRole

  @@unique([userId, section])
}

// ──────────────────────────────────────────────────────────────────
// User Preferences — персистентные настройки UI per-user (key/value JSON)
// ──────────────────────────────────────────────────────────────────
// Используется для хранения кастомизаций UI: ширины столбцов таблиц,
// выбранные фильтры, предпочтения сортировок и т.п.
// key формат: "<section>.<page>.<setting>" (например "prices.wb.columnWidths")
model UserPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, key])
  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────
// Reference data
// ──────────────────────────────────────────────────────────────────

model Marketplace {
  id        String               @id @default(cuid())
  name      String               @unique // "WB", "Ozon", "ДМ", "ЯМ"
  slug      String               @unique // "wb", "ozon", "dm", "ym"
  sortOrder Int                  @default(0)
  articles  MarketplaceArticle[]
  barcodes  Barcode[]
}

// Направление товаров (например «Бытовая техника», «Одежда»).
// Один Direction → N брендов, через Brand.directionId.
// Product получает направление через свой бренд (никаких отдельных Product.directionId).
//
// hasSizes (Phase 17): флаг видимости секции «Размерная сетка» в форме товара.
// Одежда=true, Бытовая техника=false. Контролирует ProductForm + WB import.
model ProductDirection {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  hasSizes  Boolean  @default(false)
  brands    Brand[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id          String            @id @default(cuid())
  name        String            @unique
  sortOrder   Int               @default(0)
  directionId String?
  direction   ProductDirection? @relation(fields: [directionId], references: [id], onDelete: SetNull)
  categories  Category[]
  products    Product[]
}

model Category {
  id            String             @id @default(cuid())
  name          String
  brandId       String
  brand         Brand              @relation(fields: [brandId], references: [id], onDelete: Restrict)
  sortOrder     Int                @default(0)
  subcategories Subcategory[]
  products      Product[]
  // Phase 17 — Свойства определяются на уровне категории
  properties    CategoryProperty[]

  // Phase 7: default процент брака (D-01)
  defaultDefectRatePct Float?

  @@unique([name, brandId])
}

model Subcategory {
  id         String    @id @default(cuid())
  name       String
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sortOrder  Int       @default(0)
  products   Product[]

  // Phase 7: default ДРР (D-01)
  defaultDrrPct Float?

  @@unique([name, categoryId])
}

// Phase 17: Свойства товаров — EAV, привязка к Категории (D-01).
// Один CategoryProperty → N ProductPropertyValue (per товар).
// kind=ENUM требует непустой options[]; STRING/NUMBER — options игнорируются.
// wbAttrName — имя в WB Content API characteristics[].name для авто-импорта.
enum PropertyKind {
  STRING
  ENUM
  NUMBER
}

model CategoryProperty {
  id            String                 @id @default(cuid())
  categoryId    String
  category      Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name          String
  kind          PropertyKind           @default(STRING)
  options       String[]               @default([])
  wbAttrName    String?
  // Phase 18: флаг включения value этого свойства в автогенерируемое Product.name
  includeInName Boolean                @default(false)
  sortOrder     Int                    @default(0)
  values        ProductPropertyValue[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@unique([categoryId, name])
}

// Phase 17: Значение свойства per товар.
// Один Product → N значений (по одному на CategoryProperty).
// value: всегда String — multi-value хранится через разделитель ", " (normalizeWbValue).
model ProductPropertyValue {
  id         String           @id @default(cuid())
  productId  String
  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  propertyId String
  property   CategoryProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  value      String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([productId, propertyId])
  @@index([propertyId])
}

// Phase 17: Размер товара — отдельная сущность (D-04).
// Видим в UI если у направления товара hasSizes=true.
// В будущих фазах сюда добавим barcode, weightKg для per-size остатков/продаж.
//
// 2026-05-11: barcodes — back-relation 1:N, Barcode.productSizeId nullable FK.
// Один размер → N штрих-кодов (WB может выдавать дубли в sizes[].skus).
model ProductSize {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  value     String
  sortOrder Int       @default(0)
  barcodes  Barcode[]
  createdAt DateTime  @default(now())

  @@unique([productId, value])
  @@index([productId])
}

// ──────────────────────────────────────────────────────────────────
// WB Cards (парсинг карточек Wildberries)
// ──────────────────────────────────────────────────────────────────

model WbCard {
  id                  String                  @id @default(cuid())
  nmId                Int                     @unique // WB nm_id
  article             String // артикул WB
  barcode             String? // основной штрихкод
  barcodes            String[] // все штрихкоды
  name                String
  brand               String?
  category            String? // категория WB (не наша)
  photoUrl            String? // главное фото
  photos              String[] // все фото из карточки
  hasVideo            Boolean                 @default(false) // есть ли видео
  weightKg            Float? // вес брутто, кг
  heightCm            Float? // высота, см
  widthCm             Float? // ширина, см
  depthCm             Float? // глубина (длина), см
  rating              Float? // средний рейтинг
  reviewsTotal        Int? // общее кол-во оценок
  reviews1            Int? // оценок 1
  reviews2            Int? // оценок 2
  reviews3            Int? // оценок 3
  reviews4            Int? // оценок 4
  reviews5            Int? // оценок 5
  // Phase 260514-mci: imt-агрегат рейтинга (агрегация feedback'ов всех nmId одной imt-склейки)
  imtId               Int? // id склейки из WB Content API (характеристика товара)
  ratingImt           Float? // средний рейтинг склейки (наш расчёт по Feedbacks API)
  reviewsTotalImt     Int? // кол-во оценок склейки (наш расчёт по Feedbacks API)
  // 2026-05-15: точные значения с витрины WB (card.wb.ru v4) — то что видит покупатель.
  // Заполняются в /api/wb-sync и /api/wb-sync-spp через curl. WB v4 не различает per-nmId
  // и per-imt — для всех карточек склейки возвращает одинаковую цифру (= рейтинг склейки).
  wbStoreRating       Float? // рейтинг склейки с витрины WB
  wbStoreFeedbacks    Int? // кол-во отзывов склейки с витрины WB
  // 2026-05-15 (quick 260515-kes): soft-delete для карточек удалённых в WB cabinet.
  // При sync nmId не пришёл от Content API → deletedAt = now. При повторном появлении —
  // обнуляется. Через 30 дней после deletedAt — hard-delete (cascade FK на CalculatedPrice,
  // WbCardWarehouseStock, WbCardWarehouseOrders).
  deletedAt           DateTime?
  priceBeforeDiscount Float? // цена продавца до скидки, руб
  sellerDiscount      Int? // скидка продавца, %
  price               Float? // цена продавца со скидкой, руб
  discountWb          Float? // скидка WB (СПП), % — с точностью до 0.1%
  clubDiscount        Int? // скидка WB клуба, %
  stockQty            Int? // остаток товара, шт (физический, без in-way)
  inWayToClient       Int? // в пути к клиенту, шт — sum по всем складам per nmId (Phase 15.1)
  inWayFromClient     Int? // возврат от клиента, шт — sum по всем складам per nmId (Phase 15.1)
  buyoutPercent       Float? // процент выкупа за месяц, %
  commFbwStd          Float? // комиссия стандартная FBW, %
  commFbsStd          Float? // комиссия стандартная FBS, %
  commFbwIu           Float? // комиссия ИУ FBW, %
  commFbsIu           Float? // комиссия ИУ FBS, %
  label               String?                 @db.VarChar(100) // ярлык (ручной)
  availability        String                  @default("IN_STOCK")
  rawJson             Json? // полный ответ API
  // Phase 17: парсинг WB Content API в нормализованном виде.
  // characteristics: массив { id, name, value }, value может быть string/number/array.
  // techSizes: ["S","M","L"] из sizes[].techSize (исключая "0" для one-size товаров).
  characteristics     Json?
  techSizes           String[]                @default([])
  // Phase 7: Средняя скорость продаж за 7 дней (D-09)
  avgSalesSpeed7d     Float?
  // Заказы минус отмены за вчерашний день (Moscow TZ) — для сравнения с 7д-средней
  ordersYesterday     Int?
  // Phase 7: Relation to calculated prices (D-03)
  calculatedPrices    CalculatedPrice[]
  // Phase 14: Per-warehouse stock breakdown
  warehouses          WbCardWarehouseStock[]
  // Phase 15: Per-warehouse orders breakdown (ORDERS-01)
  warehouseOrders     WbCardWarehouseOrders[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  // Phase 260514-mci: индекс для быстрой группировки при batch update ratingImt/reviewsTotalImt
  @@index([imtId])
  // 2026-05-15 (quick 260515-kes): фильтр-индекс для page queries WHERE deletedAt IS NULL.
  @@index([deletedAt])
}

// ──────────────────────────────────────────────────────────────────
// Индивидуальные условия комиссий WB (загружаются из Excel)
// ──────────────────────────────────────────────────────────────────

model WbCommissionIu {
  id          String @id @default(cuid())
  parentName  String // родительская категория WB
  subjectName String @unique // предмет (ключ связки с WbCard.category)
  fbw         Float // Склад WB, %
  fbs         Float // Склад продавца → WB, %
  dbs         Float // Доставка продавцом, %
  express     Float // Экспресс, %
  pickup      Float // Самовывоз, %
  booking     Float // Бронирование, %
}

// ──────────────────────────────────────────────────────────────────
// Product
// ──────────────────────────────────────────────────────────────────

model Product {
  id                       String                 @id @default(cuid())
  sku                      String                 @unique // "УКТ-000001" — auto-generated via PostgreSQL sequence
  // Phase 18: name стал автогенерируемым составным, бывший name → article
  article                  String                 @db.VarChar(100)
  name                     String                 @db.VarChar(255) // autogenerated по формуле; ручное редактирование — через nameOverridden
  nameOverridden           Boolean                @default(false)
  photoUrl                 String?
  brandId                  String
  brand                    Brand                  @relation(fields: [brandId], references: [id], onDelete: Restrict)
  categoryId               String?
  category                 Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategoryId            String?
  subcategory              Subcategory?           @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  label                    String?                @db.VarChar(100)
  abcStatus                AbcStatus?
  availability             Availability           @default(IN_STOCK)
  weightKg                 Float?
  heightCm                 Float?
  widthCm                  Float?
  depthCm                  Float?
  // Volume is NOT stored — computed at read time: (heightCm * widthCm * depthCm) / 1000 liters
  articles                 MarketplaceArticle[]
  cost                     ProductCost? // One-to-one: product → cost record
  // Phase 17 — Свойства (EAV) и размерная сетка
  propertyValues           ProductPropertyValue[]
  sizes                    ProductSize[]
  // Phase 14: Stock management fields
  ivanovoStock             Int?
  productionStock          Int?
  ivanovoStockUpdatedAt    DateTime?
  productionStockUpdatedAt DateTime?
  // Phase 7: Pricing overrides (D-01)
  // ── Pricing overrides (Phase 7 + 2026-04-16 extension) ──
  drrOverridePct           Float?
  defectRateOverridePct    Float?
  deliveryCostRub          Float?
  // Per-product overrides, 2026-04-16: перекрывают card.X / rates.X / subcategory/category defaults
  buyoutOverridePct        Float?
  clubDiscountOverridePct  Float?
  walletOverridePct        Float?
  acquiringOverridePct     Float?
  commissionOverridePct    Float?
  jemOverridePct           Float?
  creditOverridePct        Float?
  overheadOverridePct      Float?
  taxOverridePct           Float?
  deletedAt                DateTime? // Soft delete: null = active
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
}

// ──────────────────────────────────────────────────────────────────
// Product Cost (Себестоимость)
// ──────────────────────────────────────────────────────────────────

model ProductCost {
  id        String   @id @default(cuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  costPrice Float // Себестоимость в рублях (с точностью до копеек)
  updatedAt DateTime @updatedAt
}

model MarketplaceArticle {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplaceId String
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id])
  article       String // Marketplace article number
  // 260421-iq7: порядок артикулов внутри (productId, marketplaceId).
  // Первый (sortOrder=0) считается «основным» артикулом маркетплейса.
  sortOrder     Int         @default(0)
  barcodes      Barcode[]
  createdAt     DateTime    @default(now())

  // Uniqueness enforced by partial index migration — see migrations/20260405_partial_indexes
  // Up to 10 articles per marketplace per product enforced in service layer
}

model Barcode {
  id                   String             @id @default(cuid())
  marketplaceArticleId String
  marketplaceArticle   MarketplaceArticle @relation(fields: [marketplaceArticleId], references: [id], onDelete: Cascade)
  // Денормализация marketplaceId — нужна для partial unique index (marketplaceId, value)
  // WHERE productDeletedAt IS NULL. PostgreSQL не поддерживает subquery в UNIQUE partial
  // index predicate, поэтому ссылку на marketplace держим прямо в таблице Barcode.
  marketplaceId        String
  marketplace          Marketplace        @relation(fields: [marketplaceId], references: [id])
  value                String
  // Денормализация Product.deletedAt — ТРЕБУЕТСЯ потому что PG не разрешает subquery
  // в partial unique predicate. Синхронизируется server action'ом
  // softDeleteProduct/restoreProduct: в одной транзакции обновляется Product.deletedAt
  // и Barcode.productDeletedAt всех штрих-кодов этого товара через цепочку
  // barcode.updateMany({ where: { marketplaceArticle: { productId } } }).
  productDeletedAt     DateTime?
  // Phase 17 (2026-05-11): привязка штрих-кода к размеру товара (nullable).
  // WB Content API возвращает sizes[].skus[] — каждый размер имеет свой штрих-код.
  // null = «без размера» (одно-размерные товары: бытовая техника, аксессуары).
  // onDelete: SetNull — удаление ProductSize не удаляет штрих-код, только обнуляет связь.
  productSizeId        String?
  productSize          ProductSize?       @relation(fields: [productSizeId], references: [id], onDelete: SetNull)
  createdAt            DateTime           @default(now())
  // Partial unique index (marketplaceId, value) WHERE productDeletedAt IS NULL создан
  // в миграции 20260421_article_sortorder_barcode_fk.
  // 1-20 barcodes per MarketplaceArticle enforced in service layer.

  @@index([productSizeId])
}

// ──────────────────────────────────────────────────────────────────
// Employees
// ──────────────────────────────────────────────────────────────────

enum Department {
  OFFICE
  WAREHOUSE
}

enum Gender {
  MALE
  FEMALE
}

enum PhoneType {
  PERSONAL
  WORK
}

enum EmailType {
  PERSONAL
  WORK
}

model Company {
  id        String            @id @default(cuid())
  name      String            @unique
  employees EmployeeCompany[]
  createdAt DateTime          @default(now())
}

model Employee {
  id          String            @id @default(cuid())
  lastName    String
  firstName   String
  middleName  String?
  department  Department?
  gender      Gender?
  passNumbers Int[]
  birthDate   DateTime?
  hireDate    DateTime?
  fireDate    DateTime?
  companies   EmployeeCompany[]
  phones      EmployeePhone[]
  emails      EmployeeEmail[]
  passes      EmployeePass[]
  user        User?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model EmployeeCompany {
  id                   String    @id @default(cuid())
  employeeId           String
  employee             Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId            String
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  position             String?
  hireDate             DateTime?
  fireDate             DateTime?
  rate                 Decimal   @default(1) @db.Decimal(3, 2)
  salary               Int?
  trudovoyDogovor      Boolean   @default(false)
  prikazPriema         Boolean   @default(false)
  soglasiePersDannyh   Boolean   @default(false)
  nda                  Boolean   @default(false)
  lichnayaKartochka    Boolean   @default(false)
  zayavlenieUvolneniya Boolean   @default(false)
  prikazUvolneniya     Boolean   @default(false)

  @@unique([employeeId, companyId])
}

model EmployeePhone {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  number     String
  type       PhoneType @default(WORK)
}

model EmployeeEmail {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  email      String
  type       EmailType @default(WORK)
}

model EmployeePass {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  number     String
}

// ──────────────────────────────────────────────────────────────────
// Phase 7: Управление ценами WB
// ──────────────────────────────────────────────────────────────────

// Глобальные настройки KeyValue (D-02)
// Ключи Phase 7: wbWalletPct, wbAcquiringPct, wbJemPct, wbCreditPct, wbOverheadPct, wbTaxPct
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// Расчётные цены пользователя — до 3 слотов на WbCard (D-03)
model CalculatedPrice {
  id                String   @id @default(cuid())
  wbCardId          String
  wbCard            WbCard   @relation(fields: [wbCardId], references: [id], onDelete: Cascade)
  slot              Int // 1 | 2 | 3
  name              String
  sellerPrice       Float
  sellerDiscountPct Float?
  drrPct            Float?
  defectRatePct     Float?
  deliveryCostRub   Float?
  // Per-slot overrides, 2026-04-16: перекрывают Product.*Override / card.X / rates.X
  buyoutPct         Float?
  clubDiscountPct   Float?
  walletPct         Float?
  acquiringPct      Float?
  commissionPct     Float?
  jemPct            Float?
  creditPct         Float?
  overheadPct       Float?
  taxPct            Float?
  costPrice         Float?
  snapshot          Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([wbCardId, slot])
}

// Акции WB — sync через /api/v1/calendar/promotions (D-04)
// id = promotionID из WB API (не cuid — сопоставление прямое)
model WbPromotion {
  id            Int                       @id
  name          String
  /// Пользовательское название для UI. Null → показывать name. Сохраняется
  /// между синхронизациями (sync обновляет только name из WB API).
  displayName   String?
  description   String?
  advantages    String[]                  @default([])
  startDateTime DateTime
  endDateTime   DateTime
  type          String // "auto" | "regular"
  rangingJson   Json?
  source        String                    @default("API") // "API" | "EXCEL"
  lastSyncedAt  DateTime                  @default(now())
  createdAt     DateTime                  @default(now())
  nomenclatures WbPromotionNomenclature[]
}

// Номенклатуры акций — связь nmId с WbPromotion (D-04)
// Для regular — заполняется через API, для auto — через Excel upload
model WbPromotionNomenclature {
  id           String      @id @default(cuid())
  promotionId  Int
  promotion    WbPromotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  nmId         Int
  inAction     Boolean     @default(false)
  planPrice    Float?
  planDiscount Float?
  currentPrice Float?
  status       String?

  @@unique([promotionId, nmId])
}

// ──────────────────────────────────────────────────────────────────
// Служба поддержки — Phase 8 (v1.1)
// ──────────────────────────────────────────────────────────────────
// Единая модель для всех каналов поддержки: отзывы/вопросы WB (Phase 8),
// возвраты (Phase 9), чаты WB (Phase 10), апелляции (Phase 11),
// мессенджеры (Phase 12). Ticket = одна нить общения, Message = одно
// сообщение, Media = вложения. Customer — для Phase 12 (MVP не создаёт).

enum TicketChannel {
  FEEDBACK // отзыв WB (Phase 8)
  QUESTION // вопрос WB (Phase 8)
  CHAT // Phase 10
  RETURN // Phase 9
  MESSENGER // Phase 12
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  ANSWERED
  CLOSED
  APPEALED // Phase 11
}

enum AppealStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT // Phase 10 — PDF из chat attachments.files[]
}

// Phase 12 — подтип мессенджер-канала (Telegram/WhatsApp/OTHER)
enum MessengerType {
  TELEGRAM
  WHATSAPP
  OTHER
}

// Customer — карточка покупателя (Phase 12). В Phase 8 записи не создаются,
// т.к. WB Feedbacks/Questions API не возвращает wbUserId.
model Customer {
  id        String          @id @default(cuid())
  wbUserId  String?         @unique
  phone     String?
  name      String?
  note      String?         @db.Text
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tickets   SupportTicket[]
}

// SupportTicket — одна нить общения (отзыв, вопрос, возврат и т.п.).
// Связь с WbCard через nmId — БЕЗ FK (паттерн проекта, см. CLAUDE.md).
// wbExternalId: String? — WB возвращает cuid-like 20-символьные строки.
model SupportTicket {
  id               String           @id @default(cuid())
  channel          TicketChannel
  wbExternalId     String? // ID из WB API (feedback.id / question.id)
  customerId       String?
  customer         Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  nmId             Int? // связь с WbCard.nmId без FK
  status           TicketStatus     @default(NEW)
  assignedToId     String?
  assignedTo       User?            @relation("SupportAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  rating           Int? // productValuation 1-5 (только FEEDBACK)
  appealStatus     AppealStatus? // Phase 11
  appealId         String? // Phase 11
  appealedAt       DateTime? // Phase 11 — auto-set при createAppeal
  appealResolvedAt DateTime? // Phase 11 — auto-set при переводе PENDING → APPROVED|REJECTED
  appealRecord     AppealRecord?    @relation("Appeal") // Phase 11 — back-relation 1:1
  lastMessageAt    DateTime?
  previewText      String?          @db.Text // первые 140 символов последнего INBOUND
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  resolvedAt       DateTime?
  messages         SupportMessage[]

  // ── Phase 9: Возвраты ──
  wbClaimStatus   Int? // оригинальный status из WB (denormalized, для диагностики)
  wbClaimStatusEx Int? // status_ex из WB
  wbClaimType     Int? // claim_type из WB
  wbActions       String[]         @default([]) // актуальные action strings из WB (для UI кнопок)
  wbComment       String?          @db.Text // wb_comment — длинная инструкция покупателю
  srid            String? // Shipment ID из WB (для связки с заказом)
  price           Float? // price из заявки (рубли)
  wbOrderDt       DateTime? // order_dt из WB claim — дата заказа покупателя
  returnState     ReturnState? // локальное состояние (PENDING/APPROVED/REJECTED)
  returnDecisions ReturnDecision[] @relation("ReturnDecisions")

  // ── Phase 10: CHAT канал ──
  chatReplySign        String? // replySign из WB Chat API для sendMessage (ротируется при каждом sync)
  customerNameSnapshot String? // clientName из WB (до линковки с Customer в Phase 12)

  // ── Auto-link CHAT ↔ RETURN (2026-04-19) ──
  // Если новый CHAT event пришёл с nmId совпадающим с недавним RETURN тикетом,
  // auto-linking в syncChats записывает сюда return ticket.id.
  linkedReturnId String?
  linkedReturn   SupportTicket?  @relation("ReturnChatLink", fields: [linkedReturnId], references: [id], onDelete: SetNull)
  linkedChats    SupportTicket[] @relation("ReturnChatLink")

  // ── Phase 12: MESSENGER канал (Telegram/WhatsApp/другое) ──
  messengerType    MessengerType? // только для channel=MESSENGER
  messengerContact String? // "@username" или "+79991234567"

  @@unique([channel, wbExternalId])
  @@index([status])
  @@index([channel])
  @@index([nmId])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([returnState])
  @@index([channel, nmId, createdAt]) // Phase 13 — per-product агрегации (SUP-37)
}

// SupportMessage — отдельное сообщение внутри тикета.
// authorId: null = INBOUND покупатель или OUTBOUND от WB system.
model SupportMessage {
  id          String         @id @default(cuid())
  ticketId    String
  ticket      SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  direction   Direction
  text        String?        @db.Text
  authorId    String?
  author      User?          @relation("SupportAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  isAutoReply Boolean        @default(false) // Phase 10
  media       SupportMedia[]
  sentAt      DateTime       @default(now())
  wbSentAt    DateTime? // createdDate из WB API

  // ── Phase 10: CHAT канал ──
  wbEventId String? @unique // eventID из WB Chat events для идемпотентного upsert. Nullable — Phase 8/9 legacy messages не имеют.

  @@index([ticketId, sentAt])
  @@index([direction, isAutoReply, wbSentAt]) // Phase 13 — фильтр автоответов + avg response time
}

// SupportMedia — вложения к сообщениям. localPath заполняется Plan 08-02
// после скачивания в /var/www/zoiten-uploads/support/{ticketId}/{messageId}/.
// expiresAt = createdAt + 1 год — cron удаляет по истечении.
model SupportMedia {
  id            String         @id @default(cuid())
  messageId     String
  message       SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  type          MediaType
  wbUrl         String         @db.Text
  localPath     String?        @db.Text
  thumbnailPath String?        @db.Text
  sizeBytes     Int?
  createdAt     DateTime       @default(now())
  expiresAt     DateTime

  @@index([expiresAt])
}

// ──────────────────────────────────────────────────────────────────
// Phase 9 — Возвраты
// ──────────────────────────────────────────────────────────────────

enum ReturnDecisionAction {
  APPROVE // approve1, autorefund1, approvecc1
  REJECT // rejectcustom
  RECONSIDER // повторный approve* после REJECT
}

enum ReturnState {
  PENDING // заявка открыта, решения нет
  APPROVED // одобрен (финал)
  REJECTED // отклонён (можно пересмотреть)
}

// ReturnDecision — история решений по заявке на возврат (audit log).
// Один ticket → до N decisions (из-за «пересмотреть»).
// Актуальное состояние денормализовано в SupportTicket.returnState для быстрой фильтрации.
model ReturnDecision {
  id           String               @id @default(cuid())
  ticketId     String
  ticket       SupportTicket        @relation("ReturnDecisions", fields: [ticketId], references: [id], onDelete: Cascade)
  action       ReturnDecisionAction
  wbAction     String // оригинальный WB action (autorefund1/approve1/approvecc1/rejectcustom)
  reason       String?              @db.Text // comment для rejectcustom или approvecc1
  decidedById  String
  decidedBy    User                 @relation("ReturnDecider", fields: [decidedById], references: [id], onDelete: Restrict)
  decidedAt    DateTime             @default(now())
  reconsidered Boolean              @default(false) // true для RECONSIDER action
  wbResponseOk Boolean              @default(true) // false если WB API вернул ошибку (но попытку фиксируем)
  wbError      String?              @db.Text

  @@index([ticketId, decidedAt])
  @@index([decidedById])
}

// ──────────────────────────────────────────────────────────────────
// Phase 11 — Шаблоны ответов (local-only, WB API отключён 2025-11-19)
// ──────────────────────────────────────────────────────────────────
// Хранилище 100% локальное — WB endpoints /api/v1/templates отключены.
// Переменные {имя_покупателя}/{название_товара} подставляются при выборе
// шаблона в picker (клиентская substituteTemplateVars из lib/template-vars.ts).
// Канал ограничен Zod'ом в server action до FEEDBACK/QUESTION/CHAT (не RETURN/MESSENGER).
model ResponseTemplate {
  id           String        @id @default(cuid())
  name         String // уникальное имя в рамках канала
  text         String        @db.Text
  channel      TicketChannel // FEEDBACK | QUESTION | CHAT (валидация в Zod)
  situationTag String? // свободный тег «Положительный», «Негативный 1★», «Размер»
  nmId         Int? // опциональная привязка к товару (без FK — паттерн проекта)
  isActive     Boolean       @default(true)
  createdById  String?
  createdBy    User?         @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById  String?
  updatedBy    User?         @relation("TemplateUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([name, channel])
  @@index([channel, isActive])
  @@index([nmId])
  @@index([situationTag])
}

// ──────────────────────────────────────────────────────────────────
// Phase 11 — Трекер обжалований (hybrid manual, WB API отключён 2025-12-08)
// ──────────────────────────────────────────────────────────────────
// WB endpoint POST /api/v1/feedbacks/actions отключён — менеджер создаёт
// локальную запись + вручную подаёт жалобу в ЛК WB через jump-link.
// Ручной переключатель статуса (PENDING → APPROVED|REJECTED) после ответа WB.
// Один ticket → один AppealRecord (повтор через API невозможен, локальный повтор = update).
model AppealRecord {
  id               String        @id @default(cuid())
  ticketId         String        @unique
  ticket           SupportTicket @relation("Appeal", fields: [ticketId], references: [id], onDelete: Cascade)
  reason           String // label причины из APPEAL_REASONS (денормализованно — чтобы изменение справочника не ломало историю)
  text             String        @db.Text // свободный комментарий менеджера 10-1000 символов
  status           AppealStatus  @default(PENDING)
  createdById      String
  createdBy        User          @relation("AppealCreator", fields: [createdById], references: [id], onDelete: Restrict)
  resolvedById     String?
  resolvedBy       User?         @relation("AppealResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  appealResolvedAt DateTime?

  @@index([status])
  @@index([createdAt])
}

// ──────────────────────────────────────────────────────────────────
// Phase 10 — Чат + Автоответы (singleton)
// ──────────────────────────────────────────────────────────────────
// Singleton — id всегда = "default". Локальная feature ERP (у WB нет
// endpoint'а для автоответов). Cron /api/cron/support-sync-chat (5 мин)
// читает конфиг и отправляет OUTBOUND сообщения с isAutoReply=true
// вне рабочих часов (workDays + workdayStart/End по timezone).
model AutoReplyConfig {
  id           String   @id // всегда "default"
  isEnabled    Boolean  @default(false)
  workdayStart String   @default("09:00") // "HH:MM" в timezone
  workdayEnd   String   @default("18:00") // "HH:MM" в timezone
  workDays     Int[]    @default([1, 2, 3, 4, 5]) // ISO 8601: 1=Mon, 7=Sun
  messageText  String   @default("Здравствуйте, {имя_покупателя}! Спасибо за обращение по товару «{название_товара}». Мы ответим в рабочее время.") @db.Text
  timezone     String   @default("Europe/Moscow")
  updatedById  String?
  updatedBy    User?    @relation("AutoReplyUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt    DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────
// Phase 14: Stock Management
// ──────────────────────────────────────────────────────────────────

model WbWarehouse {
  id                 Int                     @id // warehouseId из WB Analytics API
  name               String // "Коледино", "Казань"
  cluster            String // Полное название, напр. "Центральный федеральный округ"
  shortCluster       String // "ЦФО" | "ЮГ" | "Урал" | "ПФО" | "СЗО" | "СФО" | "Прочие"
  isActive           Boolean                 @default(true)
  needsClusterReview Boolean                 @default(false)
  stocks             WbCardWarehouseStock[]
  orders             WbCardWarehouseOrders[]
}

model WbCardWarehouseStock {
  id          String      @id @default(cuid())
  wbCardId    String
  wbCard      WbCard      @relation(fields: [wbCardId], references: [id], onDelete: Cascade)
  warehouseId Int
  warehouse   WbWarehouse @relation(fields: [warehouseId], references: [id])
  // Phase 16 (STOCK-31): per-size остаток. "" = legacy/неизвестно (после миграции
  // все rows с techSize="" удалены, при первом sync API заполнит реальные значения
  // вроде "46", "48", "S", "M" или "0" для одно-размерных товаров).
  techSize    String      @default("")
  quantity    Int         @default(0)
  updatedAt   DateTime    @updatedAt

  @@unique([wbCardId, warehouseId, techSize])
  @@index([wbCardId])
  @@index([warehouseId])
}

// Phase 15: Per-warehouse orders (ORDERS-01)
// Заказы минус отмены за periodDays (default 7 дней) per (wbCardId, warehouseId).
// Обновляется при /api/wb-sync через fetchOrdersPerWarehouse + clean-replace per wbCardId.
// Clean-replace: deleteMany NOT IN incoming + upsert по unique (wbCardId, warehouseId).
model WbCardWarehouseOrders {
  id          String      @id @default(cuid())
  wbCardId    String
  wbCard      WbCard      @relation(fields: [wbCardId], references: [id], onDelete: Cascade)
  warehouseId Int
  warehouse   WbWarehouse @relation(fields: [warehouseId], references: [id])
  ordersCount Int         @default(0)
  periodDays  Int         @default(7)
  updatedAt   DateTime    @updatedAt

  @@unique([wbCardId, warehouseId])
  @@index([wbCardId])
  @@index([warehouseId])
}

// ──────────────────────────────────────────────────────────────────
// Phase 13 — Статистика службы поддержки
// ──────────────────────────────────────────────────────────────────
// Денормализованная статистика менеджеров (SUP-39). Один row на
// (userId, period), где period = 1-е число месяца 00:00 Europe/Moscow.
// Обновляется cron'ом раз в сутки 03:00 МСК (текущий месяц) через upsert.
// Past months — immutable после закрытия месяца (cron пишет только current month).
// Глобальный счётчик автоответов хранится отдельно (не per-manager, D-02).
model ManagerSupportStats {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation("ManagerStats", fields: [userId], references: [id], onDelete: Cascade)
  period             DateTime // 1st of month 00:00 Europe/Moscow (+03:00)
  totalProcessed     Int      @default(0) // D-04 outcome-actions only: OUTBOUND !isAutoReply by user + ReturnDecision by user + AppealRecord resolved by user
  feedbacksAnswered  Int      @default(0) // COUNT OUTBOUND SupportMessage где ticket.channel=FEEDBACK AND authorId=userId AND isAutoReply=false
  questionsAnswered  Int      @default(0) // same для QUESTION
  chatsAnswered      Int      @default(0) // same для CHAT
  returnsDecided     Int      @default(0) // COUNT ReturnDecision где decidedById=userId AND action IN (APPROVE, REJECT, RECONSIDER)
  returnsApproved    Int      @default(0) // COUNT ReturnDecision где decidedById=userId AND action IN (APPROVE, RECONSIDER) — для расчёта % одобрения
  returnsRejected    Int      @default(0) // COUNT ReturnDecision где decidedById=userId AND action=REJECT
  appealsResolved    Int      @default(0) // COUNT AppealRecord где resolvedById=userId
  avgResponseTimeSec Int? // nullable — null если за период у менеджера не было OUTBOUND ответов
  updatedAt          DateTime @updatedAt

  @@unique([userId, period])
  @@index([period])
}

// ──────────────────────────────────────────────────────────────────
// Quick 260512-jxh: WB API токены — CRUD через UI вместо SSH.
// Source of truth для трёх токенов: WB_API_TOKEN, WB_RETURNS_TOKEN, WB_CHAT_TOKEN.
// Bootstrap из process.env при пустой БД (см. lib/wb-token.ts).
// ──────────────────────────────────────────────────────────────────

model WbApiToken {
  name           String    @id // "WB_API_TOKEN" | "WB_RETURNS_TOKEN" | "WB_CHAT_TOKEN"
  value          String // Полное значение JWT (нужно для авторизации в WB API)
  scopeBitmask   Int // `s` из JWT payload (sum 2^bit)
  issuedAt       DateTime? // `iat` из JWT — nullable, WB часто не выставляет
  expiresAt      DateTime // `exp` из JWT
  sellerId       String? // `sid` из JWT (для аудита)
  organizationId String? // `oid` из JWT (для аудита)
  updatedById    String? // null для bootstrap из env
  updatedBy      User?     @relation("WbTokenUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ──────────────────────────────────────────────────────────────────
// Quick 260515-m5o: snapshot заказов per nmId per day для bar chart на /cards/wb.
// Daily cron 05:00 МСК пишет qty за вчерашний день; backfill с 2026-04-01 одноразовый.
// Только дни с qty > 0 хранятся — fill пустых дней делается на сервере при сборке chart timeSeries.
// NOTE: nmId хранится как Int без FK на WbCard — WbCard может быть soft/hard-deleted,
// а исторические orders должны выживать.
// ──────────────────────────────────────────────────────────────────

model WbCardOrdersDaily {
  id          Int      @id @default(autoincrement())
  nmId        Int
  date        DateTime @db.Date
  qty         Int
  // 2026-05-15 (quick 260515-o4o): snapshot цены продавца и покупателя на дату.
  // sellerPrice = WbCard.price (₽, после seller-скидки).
  // buyerPrice = round(card.wb.ru v4 sizes[].price.product / 100) — финальная витринная цена,
  //   уже включает SPP + кошелёк + клуб + промо. НЕ умножать дополнительно на (1 - walletPct/100).
  sellerPrice Int?
  buyerPrice  Int?
  // Future: sumRub Decimal?, returnsQty Int?, cancelQty Int? — расширение в следующих фазах.
  createdAt   DateTime @default(now())

  @@unique([nmId, date])
  @@index([nmId])
  @@index([date])
}

// ──────────────────────────────────────────────────────────────────
// Phase 19: Управление рекламой WB. Источник данных — WB Advert API
// (advert-api.wildberries.ru). Связь с нашими товарами через nmId БЕЗ FK
// (паттерн проекта — WbCard может быть soft-delete, исторические данные выживают).
// Daily cron /api/cron/wb-adv-sync в ~3:00 МСК + manual backfill.
// ──────────────────────────────────────────────────────────────────

model WbAdvertCampaign {
  advertId    Int                 @id // Primary key из WB (advertId)
  name        String? // Название кампании (часто пустое в WB)
  type        Int // Тип РК (4..9, актуальные см. 19-RESEARCH.md секция 2)
  status      Int // -1, 4, 7, 8, 9, 11 — справочник WB
  cpm         Int? // Текущая ставка ₽
  dailyBudget Int? // Дневной бюджет ₽
  startDate   DateTime?
  endDate     DateTime?
  changeTime  DateTime // Из API (момент последнего изменения)
  raw         Json? // Полный ответ /promotion/adverts для аудита
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  targets     WbAdvertTarget[]
  stats       WbAdvertStatDaily[]

  @@index([status])
  @@index([type])
}

// M:N campaign ↔ nmId (один advertId может бить по нескольким товарам)
// Phase 19 W0 update: /promotion/adverts (404) deprecated → targets деривируются
// из fullstats.days[].apps[].nms[].nmId как union по всем дням ответа.
// Заполняется в Plan 19-04 (cron) после fullstats sweep.
model WbAdvertTarget {
  id        Int              @id @default(autoincrement())
  advertId  Int
  nmId      Int // ссылка на WbCard.nmId БЕЗ FK
  active    Boolean          @default(true)
  campaign  WbAdvertCampaign @relation(fields: [advertId], references: [advertId], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([advertId, nmId])
  @@index([nmId])
}

// Дневная статистика per (campaign, date, nmId, platform).
// appType: 32=наблюдалось эмпирически (web?). Точное соответствие platform ↔ appType
// нужно подтвердить через несколько кампаний с разными платформами (Phase 19 follow-up).
// Source: fullstats.days[].apps[].nms[].* (см. project_wb_advert_api memory).
model WbAdvertStatDaily {
  id        Int              @id @default(autoincrement())
  advertId  Int
  date      DateTime         @db.Date // MSK day
  nmId      Int
  appType   Int // platform id из WB API
  views     Int              @default(0)
  clicks    Int              @default(0)
  ctr       Float? // %
  cpc       Float? // ₽
  sum       Float            @default(0) // потрачено ₽
  atbs      Int              @default(0) // add-to-basket
  orders    Int              @default(0) // заказы из РК
  cr        Float? // конверсия в заказ %
  shks      Int              @default(0) // штук заказано
  sumPrice  Float            @default(0) // ₽ оборот по заказам РК
  canceled  Int              @default(0) // Phase 19 W0: technical cancels (товар недоступен/доставка failed). НЕ buyer refusals.
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  campaign  WbAdvertCampaign @relation(fields: [advertId], references: [advertId], onDelete: Cascade)

  @@unique([advertId, date, nmId, appType])
  @@index([date])
  @@index([nmId, date])
}

// Snapshot баланса рекламного счёта
// Phase 19 W0 update: response — {balance: int, net: int, currency: "RUB"}, поле `bonus` ОТСУТСТВУЕТ в текущей версии API.
// Если WB вернёт bonus в будущем — добавить `bonus Int?` отдельной миграцией.
model WbAdvertBalanceSnapshot {
  id         Int      @id @default(autoincrement())
  capturedAt DateTime @default(now())
  balance    Int // основные средства ₽ (целое в API)
  net        Int // нетто ₽ (целое в API)
  currency   String   @default("RUB") // Phase 19 W0: API возвращает "RUB"

  @@index([capturedAt])
}
