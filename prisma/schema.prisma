// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────────────────

enum UserRole {
  SUPERADMIN
  MANAGER
  VIEWER
}

enum ERP_SECTION {
  PRODUCTS
  PRICES
  WEEKLY_CARDS
  STOCK
  COST
  PROCUREMENT
  SALES
  SUPPORT
  EMPLOYEES
  USER_MANAGEMENT
}

enum AbcStatus {
  A
  B
  C
}

enum Availability {
  IN_STOCK
  OUT_OF_STOCK
  DISCONTINUED
  DELETED
}

// ──────────────────────────────────────────────────────────────────
// User
// ──────────────────────────────────────────────────────────────────

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  name             String // DEPRECATED — legacy поле, для новых пользователей заполняется из firstName + lastName
  firstName        String?
  lastName         String?
  employeeId       String?            @unique
  employee         Employee?          @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  password         String // bcrypt hash — never return to client
  plainPassword    String? // plain text для просмотра суперадмином (только внутренняя ERP)
  role             UserRole           @default(VIEWER)
  allowedSections  ERP_SECTION[] // DEPRECATED — оставлено для отката миграции, см. sectionRoles
  sectionRoles     UserSectionRole[] // актуальный источник прав per раздел
  preferences      UserPreference[] // персистентные настройки UI per-user (план 260410-mya)
  assignedTickets  SupportTicket[]    @relation("SupportAssignee") // Phase 8 — назначенные тикеты поддержки
  authoredMessages SupportMessage[]   @relation("SupportAuthor") // Phase 8 — OUTBOUND сообщения
  returnDecisions  ReturnDecision[]   @relation("ReturnDecider") // Phase 9 — audit log решений по возвратам
  templatesCreated ResponseTemplate[] @relation("TemplateCreator") // Phase 11 — шаблоны, созданные пользователем
  templatesUpdated ResponseTemplate[] @relation("TemplateUpdater") // Phase 11 — шаблоны, последний раз обновлённые пользователем
  appealsCreated   AppealRecord[]     @relation("AppealCreator") // Phase 11 — обжалования, созданные пользователем
  appealsResolved  AppealRecord[]     @relation("AppealResolver") // Phase 11 — обжалования, резольвенные пользователем
  autoReplyUpdates AutoReplyConfig[]  @relation("AutoReplyUpdater") // Phase 10 — кто последний редактировал автоответ
  managerStats     ManagerSupportStats[] @relation("ManagerStats") // Phase 13 — денормализованная статистика менеджеров (SUP-39)
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

enum SectionRole {
  VIEW // только просмотр
  MANAGE // полный доступ
}

model UserSectionRole {
  id      String      @id @default(cuid())
  userId  String
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  section ERP_SECTION
  role    SectionRole

  @@unique([userId, section])
}

// ──────────────────────────────────────────────────────────────────
// User Preferences — персистентные настройки UI per-user (key/value JSON)
// ──────────────────────────────────────────────────────────────────
// Используется для хранения кастомизаций UI: ширины столбцов таблиц,
// выбранные фильтры, предпочтения сортировок и т.п.
// key формат: "<section>.<page>.<setting>" (например "prices.wb.columnWidths")
model UserPreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, key])
  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────
// Reference data
// ──────────────────────────────────────────────────────────────────

model Marketplace {
  id        String               @id @default(cuid())
  name      String               @unique // "WB", "Ozon", "ДМ", "ЯМ"
  slug      String               @unique // "wb", "ozon", "dm", "ym"
  sortOrder Int                  @default(0)
  articles  MarketplaceArticle[]
}

model Brand {
  id         String     @id @default(cuid())
  name       String     @unique
  sortOrder  Int        @default(0)
  categories Category[]
  products   Product[]
}

model Category {
  id            String        @id @default(cuid())
  name          String
  brandId       String
  brand         Brand         @relation(fields: [brandId], references: [id], onDelete: Restrict)
  sortOrder     Int           @default(0)
  subcategories Subcategory[]
  products      Product[]

  // Phase 7: default процент брака (D-01)
  defaultDefectRatePct Float?

  @@unique([name, brandId])
}

model Subcategory {
  id         String    @id @default(cuid())
  name       String
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sortOrder  Int       @default(0)
  products   Product[]

  // Phase 7: default ДРР (D-01)
  defaultDrrPct Float?

  @@unique([name, categoryId])
}

// ──────────────────────────────────────────────────────────────────
// WB Cards (парсинг карточек Wildberries)
// ──────────────────────────────────────────────────────────────────

model WbCard {
  id                  String            @id @default(cuid())
  nmId                Int               @unique // WB nm_id
  article             String // артикул WB
  barcode             String? // основной штрихкод
  barcodes            String[] // все штрихкоды
  name                String
  brand               String?
  category            String? // категория WB (не наша)
  photoUrl            String? // главное фото
  photos              String[] // все фото из карточки
  hasVideo            Boolean           @default(false) // есть ли видео
  weightKg            Float? // вес брутто, кг
  heightCm            Float? // высота, см
  widthCm             Float? // ширина, см
  depthCm             Float? // глубина (длина), см
  rating              Float? // средний рейтинг
  reviewsTotal        Int? // общее кол-во оценок
  reviews1            Int? // оценок 1
  reviews2            Int? // оценок 2
  reviews3            Int? // оценок 3
  reviews4            Int? // оценок 4
  reviews5            Int? // оценок 5
  priceBeforeDiscount Float? // цена продавца до скидки, руб
  sellerDiscount      Int? // скидка продавца, %
  price               Float? // цена продавца со скидкой, руб
  discountWb          Float? // скидка WB (СПП), % — с точностью до 0.1%
  clubDiscount        Int? // скидка WB клуба, %
  stockQty            Int? // остаток товара, шт
  buyoutPercent       Float? // процент выкупа за месяц, %
  commFbwStd          Float? // комиссия стандартная FBW, %
  commFbsStd          Float? // комиссия стандартная FBS, %
  commFbwIu           Float? // комиссия ИУ FBW, %
  commFbsIu           Float? // комиссия ИУ FBS, %
  label               String?           @db.VarChar(100) // ярлык (ручной)
  availability        String            @default("IN_STOCK")
  rawJson             Json? // полный ответ API
  // Phase 7: Средняя скорость продаж за 7 дней (D-09)
  avgSalesSpeed7d     Float?
  // Phase 7: Relation to calculated prices (D-03)
  calculatedPrices    CalculatedPrice[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

// ──────────────────────────────────────────────────────────────────
// Индивидуальные условия комиссий WB (загружаются из Excel)
// ──────────────────────────────────────────────────────────────────

model WbCommissionIu {
  id          String @id @default(cuid())
  parentName  String // родительская категория WB
  subjectName String @unique // предмет (ключ связки с WbCard.category)
  fbw         Float // Склад WB, %
  fbs         Float // Склад продавца → WB, %
  dbs         Float // Доставка продавцом, %
  express     Float // Экспресс, %
  pickup      Float // Самовывоз, %
  booking     Float // Бронирование, %
}

// ──────────────────────────────────────────────────────────────────
// Product
// ──────────────────────────────────────────────────────────────────

model Product {
  id                      String               @id @default(cuid())
  sku                     String               @unique // "УКТ-000001" — auto-generated via PostgreSQL sequence
  name                    String               @db.VarChar(100)
  photoUrl                String?
  brandId                 String
  brand                   Brand                @relation(fields: [brandId], references: [id], onDelete: Restrict)
  categoryId              String?
  category                Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategoryId           String?
  subcategory             Subcategory?         @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  label                   String?              @db.VarChar(100)
  abcStatus               AbcStatus?
  availability            Availability         @default(IN_STOCK)
  weightKg                Float?
  heightCm                Float?
  widthCm                 Float?
  depthCm                 Float?
  // Volume is NOT stored — computed at read time: (heightCm * widthCm * depthCm) / 1000 liters
  articles                MarketplaceArticle[]
  barcodes                Barcode[]
  cost                    ProductCost? // One-to-one: product → cost record
  // Phase 7: Pricing overrides (D-01)
  // ── Pricing overrides (Phase 7 + 2026-04-16 extension) ──
  drrOverridePct          Float?
  defectRateOverridePct   Float?
  deliveryCostRub         Float?
  // Per-product overrides, 2026-04-16: перекрывают card.X / rates.X / subcategory/category defaults
  buyoutOverridePct       Float?
  clubDiscountOverridePct Float?
  walletOverridePct       Float?
  acquiringOverridePct    Float?
  commissionOverridePct   Float?
  jemOverridePct          Float?
  creditOverridePct       Float?
  overheadOverridePct     Float?
  taxOverridePct          Float?
  deletedAt               DateTime? // Soft delete: null = active
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
}

// ──────────────────────────────────────────────────────────────────
// Product Cost (Себестоимость)
// ──────────────────────────────────────────────────────────────────

model ProductCost {
  id        String   @id @default(cuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  costPrice Float // Себестоимость в рублях (с точностью до копеек)
  updatedAt DateTime @updatedAt
}

model MarketplaceArticle {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplaceId String
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id])
  article       String // Marketplace article number
  createdAt     DateTime    @default(now())

  // Uniqueness enforced by partial index migration — see migrations/20260405_partial_indexes
  // Up to 10 articles per marketplace per product enforced in service layer
}

model Barcode {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  value     String
  // Uniqueness enforced by partial index migration — see migrations/20260405_partial_indexes
  // 1-20 barcodes per product enforced in service layer
}

// ──────────────────────────────────────────────────────────────────
// Employees
// ──────────────────────────────────────────────────────────────────

enum Department {
  OFFICE
  WAREHOUSE
}

enum Gender {
  MALE
  FEMALE
}

enum PhoneType {
  PERSONAL
  WORK
}

enum EmailType {
  PERSONAL
  WORK
}

model Company {
  id        String            @id @default(cuid())
  name      String            @unique
  employees EmployeeCompany[]
  createdAt DateTime          @default(now())
}

model Employee {
  id          String            @id @default(cuid())
  lastName    String
  firstName   String
  middleName  String?
  department  Department?
  gender      Gender?
  passNumbers Int[]
  birthDate   DateTime?
  hireDate    DateTime?
  fireDate    DateTime?
  companies   EmployeeCompany[]
  phones      EmployeePhone[]
  emails      EmployeeEmail[]
  passes      EmployeePass[]
  user        User?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model EmployeeCompany {
  id                   String    @id @default(cuid())
  employeeId           String
  employee             Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId            String
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  position             String?
  hireDate             DateTime?
  fireDate             DateTime?
  rate                 Decimal   @default(1) @db.Decimal(3, 2)
  salary               Int?
  trudovoyDogovor      Boolean   @default(false)
  prikazPriema         Boolean   @default(false)
  soglasiePersDannyh   Boolean   @default(false)
  nda                  Boolean   @default(false)
  lichnayaKartochka    Boolean   @default(false)
  zayavlenieUvolneniya Boolean   @default(false)
  prikazUvolneniya     Boolean   @default(false)

  @@unique([employeeId, companyId])
}

model EmployeePhone {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  number     String
  type       PhoneType @default(WORK)
}

model EmployeeEmail {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  email      String
  type       EmailType @default(WORK)
}

model EmployeePass {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  number     String
}

// ──────────────────────────────────────────────────────────────────
// Phase 7: Управление ценами WB
// ──────────────────────────────────────────────────────────────────

// Глобальные настройки KeyValue (D-02)
// Ключи Phase 7: wbWalletPct, wbAcquiringPct, wbJemPct, wbCreditPct, wbOverheadPct, wbTaxPct
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// Расчётные цены пользователя — до 3 слотов на WbCard (D-03)
model CalculatedPrice {
  id                String   @id @default(cuid())
  wbCardId          String
  wbCard            WbCard   @relation(fields: [wbCardId], references: [id], onDelete: Cascade)
  slot              Int // 1 | 2 | 3
  name              String
  sellerPrice       Float
  sellerDiscountPct Float?
  drrPct            Float?
  defectRatePct     Float?
  deliveryCostRub   Float?
  // Per-slot overrides, 2026-04-16: перекрывают Product.*Override / card.X / rates.X
  buyoutPct         Float?
  clubDiscountPct   Float?
  walletPct         Float?
  acquiringPct      Float?
  commissionPct     Float?
  jemPct            Float?
  creditPct         Float?
  overheadPct       Float?
  taxPct            Float?
  costPrice         Float?
  snapshot          Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([wbCardId, slot])
}

// Акции WB — sync через /api/v1/calendar/promotions (D-04)
// id = promotionID из WB API (не cuid — сопоставление прямое)
model WbPromotion {
  id            Int                       @id
  name          String
  /// Пользовательское название для UI. Null → показывать name. Сохраняется
  /// между синхронизациями (sync обновляет только name из WB API).
  displayName   String?
  description   String?
  advantages    String[]                  @default([])
  startDateTime DateTime
  endDateTime   DateTime
  type          String // "auto" | "regular"
  rangingJson   Json?
  source        String                    @default("API") // "API" | "EXCEL"
  lastSyncedAt  DateTime                  @default(now())
  createdAt     DateTime                  @default(now())
  nomenclatures WbPromotionNomenclature[]
}

// Номенклатуры акций — связь nmId с WbPromotion (D-04)
// Для regular — заполняется через API, для auto — через Excel upload
model WbPromotionNomenclature {
  id           String      @id @default(cuid())
  promotionId  Int
  promotion    WbPromotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  nmId         Int
  inAction     Boolean     @default(false)
  planPrice    Float?
  planDiscount Float?
  currentPrice Float?
  status       String?

  @@unique([promotionId, nmId])
}

// ──────────────────────────────────────────────────────────────────
// Служба поддержки — Phase 8 (v1.1)
// ──────────────────────────────────────────────────────────────────
// Единая модель для всех каналов поддержки: отзывы/вопросы WB (Phase 8),
// возвраты (Phase 9), чаты WB (Phase 10), апелляции (Phase 11),
// мессенджеры (Phase 12). Ticket = одна нить общения, Message = одно
// сообщение, Media = вложения. Customer — для Phase 12 (MVP не создаёт).

enum TicketChannel {
  FEEDBACK // отзыв WB (Phase 8)
  QUESTION // вопрос WB (Phase 8)
  CHAT // Phase 10
  RETURN // Phase 9
  MESSENGER // Phase 12
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  ANSWERED
  CLOSED
  APPEALED // Phase 11
}

enum AppealStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT // Phase 10 — PDF из chat attachments.files[]
}

// Phase 12 — подтип мессенджер-канала (Telegram/WhatsApp/OTHER)
enum MessengerType {
  TELEGRAM
  WHATSAPP
  OTHER
}

// Customer — карточка покупателя (Phase 12). В Phase 8 записи не создаются,
// т.к. WB Feedbacks/Questions API не возвращает wbUserId.
model Customer {
  id        String          @id @default(cuid())
  wbUserId  String?         @unique
  phone     String?
  name      String?
  note      String?         @db.Text
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tickets   SupportTicket[]
}

// SupportTicket — одна нить общения (отзыв, вопрос, возврат и т.п.).
// Связь с WbCard через nmId — БЕЗ FK (паттерн проекта, см. CLAUDE.md).
// wbExternalId: String? — WB возвращает cuid-like 20-символьные строки.
model SupportTicket {
  id               String           @id @default(cuid())
  channel          TicketChannel
  wbExternalId     String? // ID из WB API (feedback.id / question.id)
  customerId       String?
  customer         Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  nmId             Int? // связь с WbCard.nmId без FK
  status           TicketStatus     @default(NEW)
  assignedToId     String?
  assignedTo       User?            @relation("SupportAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  rating           Int? // productValuation 1-5 (только FEEDBACK)
  appealStatus     AppealStatus? // Phase 11
  appealId         String? // Phase 11
  appealedAt       DateTime? // Phase 11 — auto-set при createAppeal
  appealResolvedAt DateTime? // Phase 11 — auto-set при переводе PENDING → APPROVED|REJECTED
  appealRecord     AppealRecord?    @relation("Appeal") // Phase 11 — back-relation 1:1
  lastMessageAt    DateTime?
  previewText      String?          @db.Text // первые 140 символов последнего INBOUND
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  resolvedAt       DateTime?
  messages         SupportMessage[]

  // ── Phase 9: Возвраты ──
  wbClaimStatus   Int? // оригинальный status из WB (denormalized, для диагностики)
  wbClaimStatusEx Int? // status_ex из WB
  wbClaimType     Int? // claim_type из WB
  wbActions       String[]         @default([]) // актуальные action strings из WB (для UI кнопок)
  wbComment       String?          @db.Text // wb_comment — длинная инструкция покупателю
  srid            String? // Shipment ID из WB (для связки с заказом)
  price           Float? // price из заявки (рубли)
  wbOrderDt       DateTime? // order_dt из WB claim — дата заказа покупателя
  returnState     ReturnState? // локальное состояние (PENDING/APPROVED/REJECTED)
  returnDecisions ReturnDecision[] @relation("ReturnDecisions")

  // ── Phase 10: CHAT канал ──
  chatReplySign        String? // replySign из WB Chat API для sendMessage (ротируется при каждом sync)
  customerNameSnapshot String? // clientName из WB (до линковки с Customer в Phase 12)

  // ── Phase 12: MESSENGER канал (Telegram/WhatsApp/другое) ──
  messengerType    MessengerType? // только для channel=MESSENGER
  messengerContact String? // "@username" или "+79991234567"

  @@unique([channel, wbExternalId])
  @@index([status])
  @@index([channel])
  @@index([nmId])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([returnState])
  @@index([channel, nmId, createdAt]) // Phase 13 — per-product агрегации (SUP-37)
}

// SupportMessage — отдельное сообщение внутри тикета.
// authorId: null = INBOUND покупатель или OUTBOUND от WB system.
model SupportMessage {
  id          String         @id @default(cuid())
  ticketId    String
  ticket      SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  direction   Direction
  text        String?        @db.Text
  authorId    String?
  author      User?          @relation("SupportAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  isAutoReply Boolean        @default(false) // Phase 10
  media       SupportMedia[]
  sentAt      DateTime       @default(now())
  wbSentAt    DateTime? // createdDate из WB API

  // ── Phase 10: CHAT канал ──
  wbEventId String? @unique // eventID из WB Chat events для идемпотентного upsert. Nullable — Phase 8/9 legacy messages не имеют.

  @@index([ticketId, sentAt])
  @@index([direction, isAutoReply, wbSentAt]) // Phase 13 — фильтр автоответов + avg response time
}

// SupportMedia — вложения к сообщениям. localPath заполняется Plan 08-02
// после скачивания в /var/www/zoiten-uploads/support/{ticketId}/{messageId}/.
// expiresAt = createdAt + 1 год — cron удаляет по истечении.
model SupportMedia {
  id        String         @id @default(cuid())
  messageId String
  message   SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  type      MediaType
  wbUrl     String         @db.Text
  localPath String?        @db.Text
  sizeBytes Int?
  createdAt DateTime       @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

// ──────────────────────────────────────────────────────────────────
// Phase 9 — Возвраты
// ──────────────────────────────────────────────────────────────────

enum ReturnDecisionAction {
  APPROVE // approve1, autorefund1, approvecc1
  REJECT // rejectcustom
  RECONSIDER // повторный approve* после REJECT
}

enum ReturnState {
  PENDING // заявка открыта, решения нет
  APPROVED // одобрен (финал)
  REJECTED // отклонён (можно пересмотреть)
}

// ReturnDecision — история решений по заявке на возврат (audit log).
// Один ticket → до N decisions (из-за «пересмотреть»).
// Актуальное состояние денормализовано в SupportTicket.returnState для быстрой фильтрации.
model ReturnDecision {
  id           String               @id @default(cuid())
  ticketId     String
  ticket       SupportTicket        @relation("ReturnDecisions", fields: [ticketId], references: [id], onDelete: Cascade)
  action       ReturnDecisionAction
  wbAction     String // оригинальный WB action (autorefund1/approve1/approvecc1/rejectcustom)
  reason       String?              @db.Text // comment для rejectcustom или approvecc1
  decidedById  String
  decidedBy    User                 @relation("ReturnDecider", fields: [decidedById], references: [id], onDelete: Restrict)
  decidedAt    DateTime             @default(now())
  reconsidered Boolean              @default(false) // true для RECONSIDER action
  wbResponseOk Boolean              @default(true) // false если WB API вернул ошибку (но попытку фиксируем)
  wbError      String?              @db.Text

  @@index([ticketId, decidedAt])
  @@index([decidedById])
}

// ──────────────────────────────────────────────────────────────────
// Phase 11 — Шаблоны ответов (local-only, WB API отключён 2025-11-19)
// ──────────────────────────────────────────────────────────────────
// Хранилище 100% локальное — WB endpoints /api/v1/templates отключены.
// Переменные {имя_покупателя}/{название_товара} подставляются при выборе
// шаблона в picker (клиентская substituteTemplateVars из lib/template-vars.ts).
// Канал ограничен Zod'ом в server action до FEEDBACK/QUESTION/CHAT (не RETURN/MESSENGER).
model ResponseTemplate {
  id           String        @id @default(cuid())
  name         String // уникальное имя в рамках канала
  text         String        @db.Text
  channel      TicketChannel // FEEDBACK | QUESTION | CHAT (валидация в Zod)
  situationTag String? // свободный тег «Положительный», «Негативный 1★», «Размер»
  nmId         Int? // опциональная привязка к товару (без FK — паттерн проекта)
  isActive     Boolean       @default(true)
  createdById  String?
  createdBy    User?         @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById  String?
  updatedBy    User?         @relation("TemplateUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([name, channel])
  @@index([channel, isActive])
  @@index([nmId])
  @@index([situationTag])
}

// ──────────────────────────────────────────────────────────────────
// Phase 11 — Трекер обжалований (hybrid manual, WB API отключён 2025-12-08)
// ──────────────────────────────────────────────────────────────────
// WB endpoint POST /api/v1/feedbacks/actions отключён — менеджер создаёт
// локальную запись + вручную подаёт жалобу в ЛК WB через jump-link.
// Ручной переключатель статуса (PENDING → APPROVED|REJECTED) после ответа WB.
// Один ticket → один AppealRecord (повтор через API невозможен, локальный повтор = update).
model AppealRecord {
  id               String        @id @default(cuid())
  ticketId         String        @unique
  ticket           SupportTicket @relation("Appeal", fields: [ticketId], references: [id], onDelete: Cascade)
  reason           String // label причины из APPEAL_REASONS (денормализованно — чтобы изменение справочника не ломало историю)
  text             String        @db.Text // свободный комментарий менеджера 10-1000 символов
  status           AppealStatus  @default(PENDING)
  createdById      String
  createdBy        User          @relation("AppealCreator", fields: [createdById], references: [id], onDelete: Restrict)
  resolvedById     String?
  resolvedBy       User?         @relation("AppealResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  appealResolvedAt DateTime?

  @@index([status])
  @@index([createdAt])
}

// ──────────────────────────────────────────────────────────────────
// Phase 10 — Чат + Автоответы (singleton)
// ──────────────────────────────────────────────────────────────────
// Singleton — id всегда = "default". Локальная feature ERP (у WB нет
// endpoint'а для автоответов). Cron /api/cron/support-sync-chat (5 мин)
// читает конфиг и отправляет OUTBOUND сообщения с isAutoReply=true
// вне рабочих часов (workDays + workdayStart/End по timezone).
model AutoReplyConfig {
  id           String   @id // всегда "default"
  isEnabled    Boolean  @default(false)
  workdayStart String   @default("09:00") // "HH:MM" в timezone
  workdayEnd   String   @default("18:00") // "HH:MM" в timezone
  workDays     Int[]    @default([1, 2, 3, 4, 5]) // ISO 8601: 1=Mon, 7=Sun
  messageText  String   @default("Здравствуйте, {имя_покупателя}! Спасибо за обращение по товару «{название_товара}». Мы ответим в рабочее время.") @db.Text
  timezone     String   @default("Europe/Moscow")
  updatedById  String?
  updatedBy    User?    @relation("AutoReplyUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt    DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────
// Phase 13 — Статистика службы поддержки
// ──────────────────────────────────────────────────────────────────
// Денормализованная статистика менеджеров (SUP-39). Один row на
// (userId, period), где period = 1-е число месяца 00:00 Europe/Moscow.
// Обновляется cron'ом раз в сутки 03:00 МСК (текущий месяц) через upsert.
// Past months — immutable после закрытия месяца (cron пишет только current month).
// Глобальный счётчик автоответов хранится отдельно (не per-manager, D-02).
model ManagerSupportStats {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation("ManagerStats", fields: [userId], references: [id], onDelete: Cascade)
  period             DateTime // 1st of month 00:00 Europe/Moscow (+03:00)
  totalProcessed     Int      @default(0) // D-04 outcome-actions only: OUTBOUND !isAutoReply by user + ReturnDecision by user + AppealRecord resolved by user
  feedbacksAnswered  Int      @default(0) // COUNT OUTBOUND SupportMessage где ticket.channel=FEEDBACK AND authorId=userId AND isAutoReply=false
  questionsAnswered  Int      @default(0) // same для QUESTION
  chatsAnswered      Int      @default(0) // same для CHAT
  returnsDecided     Int      @default(0) // COUNT ReturnDecision где decidedById=userId AND action IN (APPROVE, REJECT, RECONSIDER)
  returnsApproved    Int      @default(0) // COUNT ReturnDecision где decidedById=userId AND action IN (APPROVE, RECONSIDER) — для расчёта % одобрения
  returnsRejected    Int      @default(0) // COUNT ReturnDecision где decidedById=userId AND action=REJECT
  appealsResolved    Int      @default(0) // COUNT AppealRecord где resolvedById=userId
  avgResponseTimeSec Int? // nullable — null если за период у менеджера не было OUTBOUND ответов
  updatedAt          DateTime @updatedAt

  @@unique([userId, period])
  @@index([period])
}
