// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────────────────

enum UserRole {
  SUPERADMIN
  MANAGER
  VIEWER
}

enum ERP_SECTION {
  PRODUCTS
  PRICES
  WEEKLY_CARDS
  STOCK
  COST
  PROCUREMENT
  SALES
  SUPPORT
  USER_MANAGEMENT
}

enum AbcStatus {
  A
  B
  C
}

enum Availability {
  IN_STOCK
  OUT_OF_STOCK
  DISCONTINUED
  DELETED
}

// ──────────────────────────────────────────────────────────────────
// User
// ──────────────────────────────────────────────────────────────────

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  name            String
  password        String        // bcrypt hash — never return to client
  role            UserRole      @default(VIEWER)
  allowedSections ERP_SECTION[] // Ignored when role = SUPERADMIN (per D-11)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ──────────────────────────────────────────────────────────────────
// Reference data
// ──────────────────────────────────────────────────────────────────

model Marketplace {
  id        String               @id @default(cuid())
  name      String               @unique // "WB", "Ozon", "ДМ", "ЯМ"
  slug      String               @unique // "wb", "ozon", "dm", "ym"
  sortOrder Int                  @default(0)
  articles  MarketplaceArticle[]
}

model Brand {
  id         String     @id @default(cuid())
  name       String     @unique
  sortOrder  Int        @default(0)
  categories Category[]
  products   Product[]
}

model Category {
  id            String        @id @default(cuid())
  name          String
  brandId       String
  brand         Brand         @relation(fields: [brandId], references: [id], onDelete: Restrict)
  sortOrder     Int           @default(0)
  subcategories Subcategory[]
  products      Product[]

  @@unique([name, brandId])
}

model Subcategory {
  id         String    @id @default(cuid())
  name       String
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sortOrder  Int       @default(0)
  products   Product[]

  @@unique([name, categoryId])
}

// ──────────────────────────────────────────────────────────────────
// WB Cards (парсинг карточек Wildberries)
// ──────────────────────────────────────────────────────────────────

model WbCard {
  id            String   @id @default(cuid())
  nmId          Int      @unique              // WB nm_id
  article       String                        // артикул WB
  barcode       String?                       // основной штрихкод
  barcodes      String[]                      // все штрихкоды
  name          String
  brand         String?
  category      String?                       // категория WB (не наша)
  photoUrl      String?                       // главное фото
  photos        String[]                      // все фото из карточки
  hasVideo      Boolean  @default(false)       // есть ли видео
  rating        Float?                        // средний рейтинг
  reviewsTotal  Int?                          // общее кол-во оценок
  reviews1      Int?                          // оценок 1
  reviews2      Int?                          // оценок 2
  reviews3      Int?                          // оценок 3
  reviews4      Int?                          // оценок 4
  reviews5      Int?                          // оценок 5
  price         Float?                        // цена
  label         String?  @db.VarChar(100)      // ярлык (ручной)
  availability  String   @default("IN_STOCK")
  rawJson       Json?                         // полный ответ API
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────
// Product
// ──────────────────────────────────────────────────────────────────

model Product {
  id            String               @id @default(cuid())
  name          String               @db.VarChar(100)
  photoUrl      String?
  brandId       String
  brand         Brand                @relation(fields: [brandId], references: [id], onDelete: Restrict)
  categoryId    String?
  category      Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategoryId String?
  subcategory   Subcategory?         @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  label         String?              @db.VarChar(100)
  abcStatus     AbcStatus?
  availability  Availability         @default(IN_STOCK)
  weightKg      Float?
  heightCm      Float?
  widthCm       Float?
  depthCm       Float?
  // Volume is NOT stored — computed at read time: (heightCm * widthCm * depthCm) / 1000 liters
  articles      MarketplaceArticle[]
  barcodes      Barcode[]
  deletedAt     DateTime?            // Soft delete: null = active
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model MarketplaceArticle {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  marketplaceId String
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id])
  article       String      // Marketplace article number
  createdAt     DateTime    @default(now())

  // Uniqueness enforced by partial index migration — see migrations/20260405_partial_indexes
  // Up to 10 articles per marketplace per product enforced in service layer
}

model Barcode {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  value     String
  // Uniqueness enforced by partial index migration — see migrations/20260405_partial_indexes
  // 1-20 barcodes per product enforced in service layer
}
