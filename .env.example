# ──────────────────────────────────────────────────────────────────
# Zoiten ERP — environment variables
# Copy to /etc/zoiten.pro.env on VPS (referenced by systemd EnvironmentFile)
# DO NOT commit the real .env or /etc/zoiten.pro.env to git
# ──────────────────────────────────────────────────────────────────

# Database — PostgreSQL on localhost (per D-07)
# Format: postgresql://{user}:{password}@localhost:5432/{database}
DATABASE_URL="postgresql://zoiten:CHANGE_ME_SECURE_PASSWORD@localhost:5432/zoiten_erp"

# Auth.js v5
# Generate AUTH_SECRET with: openssl rand -hex 32
AUTH_SECRET="CHANGE_ME_openssl_rand_hex_32"
# Set to https://zoiten.pro once domain is pointed; use http://85.198.97.89:3000 initially
AUTH_URL="http://85.198.97.89:3000"

# Cron purge secret — protects /api/cron/purge-deleted endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET="CHANGE_ME_openssl_rand_hex_32"

# Photo upload directory — must match nginx alias /var/www/zoiten-uploads/
UPLOAD_DIR="/var/www/zoiten-uploads"

# Node.js (set by systemd unit — do not include here)
# NODE_ENV=production
# PORT=3000
